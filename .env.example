# .env.example — copy to .env and fill in every value before running docker-compose.
# This file is committed; .env is gitignored. Never put real values here.

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=https://api.smartexpense.com
JWT_AUDIENCE=https://api.smartexpense.com
JWT_EXPIRY_MINUTES=15

# ── Admin seed user (seeded once on first startup) ───────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Gmail: use an App Password, not your login password.
# For production: use Mailgun / SendGrid / Postmark with an API key.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=noreply@smartexpense.com
FROM_NAME=SmartExpense